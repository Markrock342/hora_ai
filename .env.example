# Copy to .env.local for custom dev overrides (optional; Vite dev proxy uses /api/myhora by default).

# Production build (default in .env.production):
# VITE_MYHORA_ORIGIN=/api/myhora
# VITE_MYHORA_NET_ORIGIN=/api/myhora-net

# Remote proxy URL instead of same-origin (unusual):
# VITE_MYHORA_ORIGIN=https://your-server.example/api/myhora
